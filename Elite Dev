        <div class="card-sub">${p.weaknesses.length ? `Targeting: ${p.weaknesses.slice(0,3).join(', ')}${p.weaknesses.length > 3 ? ` +${p.weaknesses.length-3} more` : ''}` : 'No weaknesses logged yet — complete the diagnostic.'}</div>
        ${plan.map(item => `
          <div style="padding:10px 0; border-bottom:1px solid var(--border)">
            <div style="font-size:13px; color:var(--white); margin-bottom:3px">${item.focus}</div>
            <div style="font-size:12px; color:var(--text-muted)">${item.drill}</div>
          </div>`).join('')}
