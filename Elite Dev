    common: 'Too static. Receives back to goal and loses ball. Predictable movement. No weak foot finishing.'
  },
  {
    pos: 'Defensive Midfielder',
    icon: '🔒',
    keys: ['Positioning to protect back four', 'Interceptions', 'Simple passing under pressure', 'Setting tempo', 'Reading danger early'],
