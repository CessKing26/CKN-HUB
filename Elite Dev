];

// ========================
// INIT
// ========================
window.addEventListener('DOMContentLoaded', () => {
  renderPositions();
  renderAll();
  updateStats();
  updateDemoDot();
});

// ========================
// VIEWS & TABS
// ========================
function showView(v) {
  document.querySelectorAll('.view').forEach(el => el.classList.remove('active'));
  document.getElementById('view-' + v).classList.add('active');
  window.scrollTo(0, 0);
}

function switchTab(name) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  event.currentTarget.classList.add('active');
  document.getElementById('tab-' + name).classList.add('active');
}

// ========================
// MODAL
// ========================
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

function openAddPlayer() {
  // Reset form
  ['playerFirst','playerLast','playerAge','playerNotes'].forEach(id => document.getElementById(id).value = '');
  ['playerFoot','playerPosition','playerPhase'].forEach(id => document.getElementById(id).selectedIndex = 0);
  document.querySelectorAll('#weaknessTags .tag').forEach(t => t.classList.remove('selected'));
  openModal('addPlayerModal');
}

// ========================
// TAGS
// ========================
function toggleTag(el) { el.classList.toggle('selected'); }

// ========================
// SAVE PLAYER
// ========================
function savePlayer() {
  const first = document.getElementById('playerFirst').value.trim();
  const last = document.getElementById('playerLast').value.trim();
  if (!first) { alert('Please enter a player name.'); return; }

  const weaknesses = [...document.querySelectorAll('#weaknessTags .tag.selected')].map(t => t.textContent);

  const player = {
    id: Date.now(),
    first, last,
    age: document.getElementById('playerAge').value || '—',
    foot: document.getElementById('playerFoot').value || '—',
    position: document.getElementById('playerPosition').value || 'Not assigned',
    phase: document.getElementById('playerPhase').value || '1',
    weaknesses,
    notes: document.getElementById('playerNotes').value.trim(),
    created: new Date().toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric' }),
    status: 'active'
  };

  players.push(player);
  save();
  closeModal('addPlayerModal');
  renderAll();
  updateStats();
}

// ========================
// RENDER PLAYERS
// ========================
function renderAll() {
  renderPlayerList();
  renderPlansList();
  renderProgressList();
  renderDemoList();
}

function renderPlayerList() {
  const el = document.getElementById('playerList');
