          <button class="btn-ghost" onclick="openDemoModal(${i})">REQUEST DEMO</button>
        </div>
      </div>`;
  }).join('');
}

function renderProgressList() {
  const el = document.getElementById('progressList');
  if (!players.length) {
    el.innerHTML = `<div class="empty-state"><div class="empty-state-icon">📈</div><div class="empty-state-text">Progress tracking starts once a player<br>has an active development plan.</div></div>`;
    return;
  }
  el.innerHTML = players.map((p, i) => {
    const logs = progressLogs.filter(l => l.playerId === p.id);
    const latest = logs[logs.length - 1];
    const first = logs[0];
    const areas = ['Ball Mastery', 'Decision Speed', 'Weak Foot', 'Confidence', 'Positioning'];
    return `
      <div class="card">
        <div class="section-label">${p.first.toUpperCase()} ${p.last.toUpperCase()}</div>
        <div class="card-title" style="margin-bottom:4px">${p.position} · Age ${p.age}</div>
        <div class="card-sub" style="margin-bottom:16px">${logs.length ? `${logs.length} progress log${logs.length>1?'s':''} · Started ${first.date}` : 'No logs yet — add the first entry to start tracking.'}</div>
        ${areas.map(area => {
          const before = first ? (first.ratings[area] || 0) : 0;
          const after = latest ? (latest.ratings[area] || 0) : 0;
          const pct = (after / 10) * 100;
          const bPct = (before / 10) * 100;
          return `
            <div class="progress-row">
              <div class="progress-header">
                <span class="progress-name">${area}</span>
                <span class="progress-val">${before > 0 ? `${before} → ` : ''}<span style="color:var(--gold)">${after}/10</span></span>
