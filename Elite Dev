// ========================
// GENERATE PLAN
// ========================
function generatePlan(p) {
  const plans = {
    'First Touch': { focus: 'First touch under pressure', drill: 'Receive against wall, control directionally — both feet. 10 mins daily.' },
    'Weak Foot': { focus: 'Weak foot activation', drill: 'Passing circuits — weak foot only. No exceptions for 3 sessions.' },
    'Ball Mastery': { focus: 'Close control & ball confidence', drill: 'Coerver combinations — 15 mins before every session.' },
    'Decision Making': { focus: 'Speed of decision', drill: 'Rondo with 3-second rule. Force the decision before comfortable.' },
    'Receiving Under Pressure': { focus: 'Receiving on back foot', drill: 'Server presses immediately on release. Player must turn or shield.' },
    'Positional Awareness': { focus: 'Scanning before receiving', drill: 'Call out what you see before the pass arrives — 3 scans minimum.' },
    'Confidence on Ball': { focus: 'Building ball familiarity', drill: 'Street football rules — keep the ball, express. No pressure of correction.' },
    '1v1 Defending': { focus: 'Defensive body shape & patience', drill: '1v1 corridors — hold shape, force inside, no dive in.' },
    'Pressing Intensity': { focus: 'Trigger & transition press', drill: 'Define the trigger. Work on press in pairs — one press, one cover.' },
    'Movement Off Ball': { focus: 'Creating space for teammates', drill: 'Shadow runs in pairs — near post, far post, in behind. No ball needed.' },
    'Crossing': { focus: 'Delivery at pace', drill: 'Wide runs into cross — vary near, far, cutback. Both feet if possible.' },
    'Shooting Technique': { focus: 'Strike through the ball cleanly', drill: 'Technique before power. Instep drive — 20 reps each foot.' },
    'Transition Speed': { focus: 'Speed of play on/off ball', drill: 'Transition games — 3v3, two-touch, goals after winning ball only.' },
  };

  const defaults = [
    { focus: 'Foundation ball work', drill: 'Coerver basics — inside, outside, sole, cut. Daily for 10 mins.' },
    { focus: 'Technical accuracy', drill: 'Passing and receiving circuits against a wall — both feet.' },
    { focus: 'Game understanding', drill: 'Positional shadow play — movement patterns without the ball.' },
  ];

  const phaseContext = {
    '1': 'Focus: relationship with the ball. Both feet. Enjoyment.',
    '2': 'Focus: technique under fatigue. Comfort in tight space.',
    '3': 'Focus: positional function. When to press, hold, move.',
    '4': 'Focus: full game model. In/out of possession decisions.'
  };

  let items = p.weaknesses.slice(0, 4).map((w, i) => ({
    week: `${(i*1)+1}–${(i*1)+1}`,
    ...(plans[w] || defaults[i % defaults.length])
  }));

  if (items.length < 2) items = defaults.map((d, i) => ({ week: `${i+1}–${i+2}`, ...d }));

  return items.slice(0, 4);
}

// ========================
// POSITIONS
// ========================
function renderPositions() {
  const grid = document.getElementById('positionGrid');
  grid.innerHTML = POSITIONS.map((p, i) => `
