  const el = document.getElementById('plansList');
  if (!players.length) {
    el.innerHTML = `<div class="empty-state"><div class="empty-state-icon">📋</div><div class="empty-state-text">Add a player and complete their diagnostic<br>to generate their development plan.</div></div>`;
