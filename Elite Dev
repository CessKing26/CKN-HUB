      <div class="pos-sub">${p.keys.slice(0,2).join(' · ')}</div>
    </div>
  `).join('');
}

function showPositionDetail(i) {
  const p = POSITIONS[i];
  const det = document.getElementById('positionDetail');
  det.style.display = 'block';
  det.innerHTML = `
    <div class="divider"></div>
    <div class="section-label">${p.pos.toUpperCase()}</div>
    <div class="card">
      <div class="card-title" style="margin-bottom:8px">${p.icon} What this position demands</div>
      <div class="card-sub" style="margin-bottom:20px">${p.focus}</div>
      <div class="section-label">5 KEY COMPETENCIES</div>
      ${p.keys.map(k => `<div class="info-row"><span style="font-size:13px; color:var(--text)">✓ ${k}</span></div>`).join('')}
      <div style="margin-top:20px">
        <div class="section-label">TYPICAL WEAKNESSES</div>
        <div class="card-sub">${p.common}</div>
      </div>
    </div>
  `;
  det.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// ========================
// DEMO REQUEST
// ========================
function openDemoModal(index) {
  currentDemoPlayerIndex = index;
  document.getElementById('demoSkill').value = '';
  document.getElementById('demoReason').value = '';
  document.getElementById('demoUrgency').selectedIndex = 0;
  openModal('demoModal');
}

function submitDemo() {
  const skill = document.getElementById('demoSkill').value.trim();
  if (!skill) { alert('Please describe the skill needed.'); return; }
  const p = players[currentDemoPlayerIndex];
  demoRequests.push({
    playerId: p.id,
    playerName: `${p.first} ${p.last}`,
    position: p.position,
    phase: p.phase,
    skill,
    reason: document.getElementById('demoReason').value.trim(),
    urgency: document.getElementById('demoUrgency').value,
    date: new Date().toLocaleDateString('en-GB', { day:'numeric', month:'short' })
  });
  save();
  closeModal('demoModal');
  updateStats();
  updateDemoDot();
  renderDemoList();
  alert(`Demo request logged for ${p.first} ${p.last}. You\'ll be contacted directly.`);
}

function markDemoDone(i) {
  demoRequests.splice(i, 1);
  save();
  updateStats();
  updateDemoDot();
  renderDemoList();
}

// ========================
// PROGRESS
// ========================
function openProgressModal(index) {
  currentPlayerIndex = index;
  const areas = ['Ball Mastery', 'Decision Speed', 'Weak Foot', 'Confidence', 'Positioning'];
  document.getElementById('progressForm').innerHTML = areas.map(a => `
    <div class="form-group">
      <label>${a.toUpperCase()} (1–10)</label>
      <input type="number" id="prog_${a.replace(/\s/g,'')}" min="1" max="10" placeholder="Rate 1–10">
    </div>
  `).join('');
  openModal('progressModal');
}

function saveProgress() {
  const p = players[currentPlayerIndex];
  const areas = ['Ball Mastery', 'Decision Speed', 'Weak Foot', 'Confidence', 'Positioning'];
  const ratings = {};
  areas.forEach(a => {
    const val = parseInt(document.getElementById('prog_' + a.replace(/\s/g,'')).value);
    if (val) ratings[a] = val;
  });
  if (!Object.keys(ratings).length) { alert('Please rate at least one area.'); return; }
  progressLogs.push({
    playerId: p.id,
    date: new Date().toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric' }),
    ratings
  });
  save();
  closeModal('progressModal');
  renderProgressList();
}

// ========================
// DELETE
// ========================
function deletePlayer(index) {
  if (!confirm('Remove this player profile?')) return;
  players.splice(index, 1);
  save();
  showView('main');
  renderAll();
  updateStats();
}

// ========================
// STATS & UTILS
// ========================
function updateStats() {
  document.getElementById('statTotal').textContent = players.length;
  document.getElementById('statActive').textContent = players.filter(p => p.weaknesses.length > 0).length;
  document.getElementById('statDemo').innerHTML = demoRequests.length + '<span class="gold-plus">+</span>';
}

function updateDemoDot() {
  const dot = document.getElementById('demoDot');
  if (dot) dot.style.display = demoRequests.length > 0 ? 'inline-block' : 'none';
}

function save() {
  localStorage.setItem('cknElitePlayers', JSON.stringify(players));
  localStorage.setItem('cknDemoRequests', JSON.stringify(demoRequests));
  localStorage.setItem('cknProgressLogs', JSON.stringify(progressLogs));
}
</script>
</body>
</html>
